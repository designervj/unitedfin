{
  "pages": {
    "/(root)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(root)/layout.css",
      "static/chunks/app/(root)/layout.js"
    ],
    "/(root)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(root)/page.js"
    ],
    "/[locale]/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/[locale]/layout.css",
      "static/chunks/app/[locale]/layout.js"
    ],
    "/[locale]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/page.js"
    ],
    "/[locale]/services/personal-loan/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/services/personal-loan/page.js"
    ],
    "/_not-found/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/_not-found/page.js"
    ]
  }
}